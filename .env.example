# ============================================================
# Environment Variables Template for Hostinger Deployment
# ============================================================
# Copy this file to `.env` on your Hostinger server (via SSH)
# or add these in hPanel → Node.js → Environment Variables section
#
# DO NOT commit the actual `.env` file to git!
# ============================================================

# Node environment
NODE_ENV=production

# Port (Hostinger usually auto-assigns; leave blank if unsure)
# PORT=3000

# Nitro build preset (required for Hostinger Node.js hosting)
NITRO_PRESET=node-server

# ============================================================
# Future integrations (fill in when you set them up)
# ============================================================

# WordPress Contact Form 7 endpoint (for form submissions)
# Get this after installing CF7 plugin and creating a form.
# Format: https://yourdomain.com/wp-json/contact-form-7/v1/contact-forms/FORM_ID/feedback
# CF7_ENDPOINT_URL=

# Email service API key (Resend, SendGrid, etc.)
# RESEND_API_KEY=

# WhatsApp Business API (if you add it later)
# WHATSAPP_API_TOKEN=