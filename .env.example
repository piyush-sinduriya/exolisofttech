# ============================================================
# Environment Variables Template
# ============================================================
# Add these in Vercel → Project Settings → Environment Variables
#
# DO NOT commit the actual `.env` file to git!
# ============================================================

# Node environment
NODE_ENV=production

# ============================================================
# Email (Resend) — Required for contact form emails
# ============================================================
# Sign up at https://resend.com and get your API key
# Free plan: 100 emails/day, 3000 emails/month
RESEND_API_KEY=re_xxxxxxxxxxxx

# ============================================================
# Future integrations (fill in when you set them up)
# ============================================================

# WhatsApp Business API (if you add it later)
# WHATSAPP_API_TOKEN=